# Root workspace allowed for execution
WORKSPACE_ROOT=/absolute/path/to/mcp_dynamic_analysis_server

# Optional overrides
RUNS_DIR=/absolute/path/to/mcp_dynamic_analysis_server/runs
ARTIFACTS_DIR=/absolute/path/to/mcp_dynamic_analysis_server/artifacts
VALGRIND_BIN=valgrind
MAX_ARTIFACT_BYTES=2000000
MAX_ARTIFACT_PREVIEW_BYTES=20000
LOG_LEVEL=INFO

# R2 (S3 compatible) settings
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=your_bucket
R2_REGION=auto
R2_USE_SSL=true
R2_PRESIGN_EXPIRES_SEC=900
R2_UPLOAD_PREFIX=uploads
R2_MAX_UPLOAD_BYTES=20000000
R2_DOWNLOAD_TIMEOUT_SEC=60
# Comma-separated hostnames only (no scheme). Include custom domain and/or R2 endpoint host.
R2_ALLOW_HOSTS=<accountid>.r2.cloudflarestorage.com
R2_HEALTHCHECK_ON_STARTUP=false
R2_HEALTHCHECK_TIMEOUT_SEC=5
